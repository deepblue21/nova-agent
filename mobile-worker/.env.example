MOBILE_WORKER_ENABLED=0
MOBILE_WORKER_TOKEN=
MOBILE_WORKER_DEVICE_ID=emulator-5554
# WSL-to-Windows host bridge for the remote ADB server; never an Android/UI payload value.
# The Windows launcher overrides this to 127.0.0.1 and uses the local Windows ADB server.
MOBILE_WORKER_ADB_SERVER_HOST=127.0.0.1
MOBILE_WORKER_ADB_SERVER_PORT=5037
MOBILE_WORKER_LEASE_MS=120000
MOBILE_WORKER_GOAL_POLICY=settings_android_version
HORUS_GATEWAY_URL=http://127.0.0.1:8088/v1
# The Windows launcher removes this raw URL and sets MOBILE_WORKER_OLLAMA_WSL_DISTRO from -Distro.
# Keep it only for the non-Windows loopback-only worker path; do not set both values manually.
MOBILE_WORKER_OLLAMA_URL=http://127.0.0.1:11434
# MOBILE_WORKER_OLLAMA_WSL_DISTRO=Ubuntu
MOBILE_WORKER_OLLAMA_MODEL=qwen3:14b
MOBILE_WORKER_MAX_STEPS=8
MOBILE_WORKER_STATUS_POLL_SECONDS=1.0
MOBILE_WORKER_EXECUTION_TIMEOUT_SECONDS=120.0
