{
  "name": "nova-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible multi-LLM routing gateway (Anthropic / Gemini / OpenAI / Ollama / OpenClaw) with auth, CORS allowlist, and rate limiting",
  "main": "gateway.mjs",
  "scripts": {
    "start": "node gateway.mjs",
    "dev": "node --watch gateway.mjs",
    "migrate": "node migrate.mjs",
    "bootstrap": "node scripts/bootstrap-user.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "mammoth": "1.12.0",
    "pdf-parse": "1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "quickjs-emscripten": "0.31.0",
    "stripe": "^17.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}
