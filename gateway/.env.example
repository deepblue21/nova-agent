# ============================================================
#  NOVA Gateway — environment configuration
#  Copy to ".env" (cp .env.example .env) and fill in.
#  The gateway loads .env automatically. NEVER commit your real .env.
# ============================================================

# ---- Security (set these before exposing beyond localhost) ----
# Bearer token required by every request except /health. Blank = AUTH DISABLED.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_TOKEN=

# CORS allowlist (comma-separated). "*" allows any origin (dev only).
# Defaults to the Vite dev/preview origins if unset.
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Per-IP rate limit: max requests per window. 0 disables.
RATE_MAX=120
RATE_WINDOW_MS=60000

# Optional model allowlist (comma list). Supports "provider/*". Empty = all allowed.
# e.g. ALLOW_MODELS=ollama/*,gemini/gemini-2.5-flash
ALLOW_MODELS=

# Max messages per request / JSON body size / per-request timeout.
MAX_MESSAGES=400
MAX_MESSAGE_CHARS=100000
BODY_LIMIT=25mb
REQ_TIMEOUT_MS=60000
MAX_RETRIES=2
HEALTH_DETAILS_ENABLED=0

# Set to 1 only if running behind a trusted reverse proxy (enables X-Forwarded-For).
TRUST_PROXY=0
# NODE_ENV=production   # hides upstream error details from clients

# ---- Server ----
PORT=8088

# ---- Provider API keys (server-side; never shipped to the browser) ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---- Local / self-hosted backends ----
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=ollama/qwen3:14b
VISION_MODEL=ollama/qwen3.5-omni:latest

# Optional dynamic-routing overrides (effort -> model). ONLY used by `auto`
# (Dynamic Routing); a manually selected model is always respected as-is.
# Local-first example — point at your installed Ollama tags (see `ollama list`):
# ROUTE_FAST=ollama/gemma4:e2b
# ROUTE_BALANCED=ollama/gemma4:latest
# ROUTE_DEEP=ollama/qwen3.5:35b
# ROUTE_MAX=ollama/qwen3.6:35b
# ROUTE_VISION=ollama/gemma4:latest
# Cloud example:
# ROUTE_FAST=gemini/gemini-2.5-flash
# ROUTE_DEEP=anthropic/claude-sonnet-4-20250514
# ROUTE_MAX=anthropic/claude-sonnet-4-20250514

# Optional remote image URL fetch for local/non-OpenAI vision providers.
# Keep off unless you trust the network context; localhost/private IPs are blocked by default.
REMOTE_IMAGE_URLS_ENABLED=0
REMOTE_IMAGE_MAX_BYTES=10485760
REMOTE_IMAGE_MAX_REDIRECTS=2
REMOTE_IMAGE_ALLOW_PRIVATE=0

# ---- OpenClaw agent layer ----
OPENCLAW_URL=http://localhost:3000
OPENCLAW_TOKEN=
OPENCLAW_PATH=/api/agents/{agent}/messages

# ---- Voice: STT (Whisper) / TTS (OpenAI-compatible servers) ----
WHISPER_URL=http://localhost:8000/v1/audio/transcriptions
WHISPER_MODEL=Systran/faster-whisper-small
TTS_URL=http://localhost:8001/v1/audio/speech
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Optional async voice queue (BullMQ + Redis). Keep off for simple local use.
VOICE_QUEUE_ENABLED=0
VOICE_QUEUE_NAME=nova_voice
VOICE_QUEUE_CONCURRENCY=2
VOICE_QUEUE_RESULT_TTL_SEC=3600
VOICE_QUEUE_FAILED_TTL_SEC=86400
VOICE_QUEUE_MAX_AUDIO_BYTES=26214400
TTS_MAX_INPUT_CHARS=8000

# ---- Observability: OpenTelemetry traces (opt-in, zero-dep OTLP/HTTP) ----
# Leave unset to disable (default). Set to your collector's OTLP/HTTP endpoint to
# export one span per chat request (route/provider/model/agent/status).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=   # full traces URL; overrides the base above
# OTEL_SERVICE_NAME=nova-gateway
# OTEL_EXPORTER_TIMEOUT_MS=3000

# ============================================================
#  Phase 1 — multi-user core (Postgres + Redis + OIDC)
#  Required only when running the Phase 1 layer (auth, history, quotas).
#  In docker-compose these are injected automatically; set them here for
#  bare-metal / local runs.
# ============================================================

# Postgres connection string (users, conversations, usage, quotas).
DATABASE_URL=postgres://nova:nova@localhost:5432/nova
PG_POOL_MAX=10

# Redis — distributed rate limit + cache (replaces the in-process limiter).
REDIS_URL=redis://localhost:6379

# OIDC / JWT — your identity provider (Keycloak, Clerk, Auth0, …).
# The gateway validates incoming JWTs against the JWKS endpoint.
OIDC_ISSUER=
OIDC_JWKS_URL=
OIDC_AUDIENCE=

# ============================================================
#  Phase 2/3 — object storage, agent tools, RAG (bare-metal için)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=nova-media
MAX_MEDIA_BYTES=26214400
ALLOWED_MEDIA_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/webm,audio/mpeg,audio/wav,audio/ogg,video/mp4,video/webm,application/pdf
SEARXNG_URL=http://localhost:8080
AGENT_MAX_ROUNDS=4
EMBED_MODEL=nomic-embed-text
MAX_DOC_BYTES=1048576
MAX_DOC_FILE_BYTES=10485760
CODE_TOOL_ENABLED=0
CODE_TOOL_TIMEOUT_MS=1000
CODE_TOOL_MEMORY_MB=16
CODE_TOOL_MAX_CODE_CHARS=6000
CODE_TOOL_MAX_OUTPUT_CHARS=4000

# ---- docker-compose ortam değişkenleri (kök .env'den okunur) ----
# Üretimde HEPSİNİ güçlü değerlerle override et (bkz. SECURITY.md):
# POSTGRES_PASSWORD=nova
# MINIO_USER=minio
# MINIO_PASSWORD=minio12345
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# GRAFANA_PASSWORD=admin
# SEARXNG_SECRET=change-me-searxng-dev-secret
